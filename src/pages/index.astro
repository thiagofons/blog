---
import { getCollection } from "astro:content";
import Heading from "../components/Heading.astro";
import Layout from "../components/Layout.astro";

const PAGE_SIZE = 10;

const allPosts = (await getCollection("posts")).filter((post) => !post.data.draft).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const posts = allPosts.slice(0, PAGE_SIZE);
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
---

<Layout title="Thiago Fonseca" description="Reflexões de um engenheiro de software em formação.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Thiago Fonseca",
    "description": "Reflexões de um engenheiro de software em formação.",
    "url": Astro.site?.href,
    "inLanguage": "pt-BR",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${new URL("/busca", Astro.site).href}?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  })} />
  <section class="home">
    <header class="home-header">
      <Heading as="h1">Thiago Fonseca</Heading>
      <p class="home-tagline">Reflexões de um engenheiro de software em formação.</p>
    </header>

    {posts.length === 0 ? (
      <p class="empty">Nenhum artigo publicado ainda.</p>
    ) : (
      <ul class="post-list">
        {
          posts.map((post) => {
            const formattedDate = post.data.date.toLocaleDateString("pt-BR", {
              year: "numeric",
              month: "long",
              day: "numeric",
              timeZone: "UTC",
            });
            return (
              <li class="post-item">
                <a href={`/artigos/${post.id}`}>
                  <span class="post-title">{post.data.title}</span>
                  <span class="post-description">{post.data.description}</span>
                  <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                </a>
              </li>
            );
          })
        }
      </ul>
    )}

    {totalPages > 1 && (
      <nav class="pagination" aria-label="Paginação">
        <span class="pagination-info">Página 1 de {totalPages}</span>
        <a href="/pagina/2" class="pagination-link">Mais antigos &rarr;</a>
      </nav>
    )}
  </section>
</Layout>

<style>
  .home {
    max-width: var(--width-content);
    width: 100%;
    margin: 0 auto;
  }

  .home-header {
    margin-bottom: var(--space-2xl);
  }

  .home-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
  }

  .empty {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--color-text-tertiary);
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 70%, #b9b3a5 30%);
  }

  .post-item:first-child {
    border-top: 1px solid color-mix(in srgb, var(--color-border) 70%, #b9b3a5 30%);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-lg);
    text-decoration: none;
    color: var(--color-text);
  }

  .post-item a:hover .post-title {
    color: var(--color-text-secondary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
  }

  .pagination-link,
  .pagination-info {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .pagination-link:hover {
    color: var(--color-text);
  }
</style>
