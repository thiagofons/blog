---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
---

<Layout title="Links — Thiago Fonseca" description="Arquivo e busca de links salvos por tag e palavra-chave.">
  <section class="links-page">
    <header class="links-header">
      <Heading as="h1">Links</Heading>
      <p class="links-subtitle">Referências e artigos salvos por tema.</p>
    </header>

    <div class="links-grid">
      <aside class="links-tags">
        <h2>Tags</h2>
        <ul id="tags-list" class="tags-list"></ul>
      </aside>

      <div class="links-main">
        <div class="links-input-wrap">
          <input
            type="text"
            id="links-input"
            placeholder="Buscar links..."
            autocomplete="off"
            autofocus
          />
        </div>

        <ul id="links-results" class="links-results"></ul>
        <p id="links-empty" class="links-empty" hidden>Nenhum link encontrado.</p>
        <p id="links-no-items" class="links-empty" hidden>Ainda não existem links publicados.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  interface LinkEntry {
    slug: string;
    title: string;
    description: string;
    url: string;
    date: string;
    tags: string[];
    body: string;
  }

  interface TagBucket {
    key: string;
    label: string;
    count: number;
  }

  let index: LinkEntry[] = [];
  let loaded = false;
  let selectedTag: string | null = null;

  const input = document.getElementById("links-input") as HTMLInputElement;
  const resultsList = document.getElementById("links-results") as HTMLUListElement;
  const emptyMsg = document.getElementById("links-empty") as HTMLParagraphElement;
  const noItemsMsg = document.getElementById("links-no-items") as HTMLParagraphElement;
  const tagsList = document.getElementById("tags-list") as HTMLUListElement;

  async function loadIndex(): Promise<void> {
    if (loaded) return;
    const res = await fetch("/links-index.json");
    index = await res.json();
    loaded = true;
  }

  function normalizeTag(tag: string): string {
    return tag.trim().toLowerCase();
  }

  function getTagBuckets(entries: LinkEntry[]): TagBucket[] {
    const counts = new Map<string, { label: string; count: number }>();

    for (const entry of entries) {
      for (const tag of entry.tags ?? []) {
        const key = normalizeTag(tag);
        if (!key) continue;
        const existing = counts.get(key);
        if (existing) {
          existing.count += 1;
        } else {
          counts.set(key, { label: tag.trim(), count: 1 });
        }
      }
    }

    return [...counts.entries()]
      .map(([key, value]) => ({ key, label: value.label, count: value.count }))
      .sort((a, b) => {
        if (b.count !== a.count) return b.count - a.count;
        return a.label.localeCompare(b.label, "pt-BR");
      });
  }

  function buildQuery(query: string): LinkEntry[] {
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);

    return index.filter((entry) => {
      const haystack = `${entry.title} ${entry.description} ${entry.body} ${(entry.tags ?? []).join(" ")}`
        .toLowerCase();
      const textMatch = terms.length === 0 || terms.every((term) => haystack.includes(term));
      const tagMatch = !selectedTag || (entry.tags ?? []).some((tag) => normalizeTag(tag) === selectedTag);
      return textMatch && tagMatch;
    });
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString("pt-BR", {
      year: "numeric",
      month: "long",
      day: "numeric",
      timeZone: "UTC",
    });
  }

  function escapeHtml(str: string): string {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  function updateUrlState(query: string): void {
    const params = new URLSearchParams(window.location.search);
    if (query.trim()) params.set("q", query.trim());
    else params.delete("q");

    if (selectedTag) params.set("tag", selectedTag);
    else params.delete("tag");

    const next = params.toString();
    const nextUrl = next ? `/links?${next}` : "/links";
    window.history.replaceState({}, "", nextUrl);
  }

  function renderTags(buckets: TagBucket[]): void {
    tagsList.innerHTML = "";

    const allLi = document.createElement("li");
    const allBtn = document.createElement("button");
    allBtn.type = "button";
    allBtn.className = `tag-btn ${selectedTag === null ? "active" : ""}`;
    allBtn.textContent = `Todas (${index.length})`;
    allBtn.addEventListener("click", () => {
      selectedTag = null;
      render(input.value);
    });
    allLi.appendChild(allBtn);
    tagsList.appendChild(allLi);

    for (const bucket of buckets) {
      const li = document.createElement("li");
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = `tag-btn ${selectedTag === bucket.key ? "active" : ""}`;
      btn.textContent = `${bucket.label} (${bucket.count})`;
      btn.addEventListener("click", () => {
        selectedTag = selectedTag === bucket.key ? null : bucket.key;
        render(input.value);
      });
      li.appendChild(btn);
      tagsList.appendChild(li);
    }
  }

  function render(query: string): void {
    const buckets = getTagBuckets(index);
    renderTags(buckets);

    resultsList.innerHTML = "";
    noItemsMsg.hidden = index.length !== 0;

    if (index.length === 0) {
      emptyMsg.hidden = true;
      return;
    }

    const results = buildQuery(query);
    updateUrlState(query);

    if (results.length === 0) {
      emptyMsg.hidden = false;
      return;
    }

    emptyMsg.hidden = true;

    for (const entry of results) {
      const li = document.createElement("li");
      li.className = "links-result-item";
      const tagsMarkup = (entry.tags ?? [])
        .map((tag) => `<span class="result-tag">${escapeHtml(tag)}</span>`)
        .join("");

      li.innerHTML = `
        <a href="${escapeHtml(entry.url)}" target="_blank" rel="noopener noreferrer">
          <span class="result-title">${escapeHtml(entry.title)}</span>
          <span class="result-description">${escapeHtml(entry.description)}</span>
          ${tagsMarkup ? `<span class="result-tags">${tagsMarkup}</span>` : ""}
          <time class="result-date" datetime="${escapeHtml(entry.date)}">${formatDate(entry.date)}</time>
        </a>
      `;
      resultsList.appendChild(li);
    }
  }

  let debounceTimer: ReturnType<typeof setTimeout>;

  input.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      render(input.value);
    }, 180);
  });

  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get("q") ?? "";
  const initialTag = params.get("tag");

  loadIndex().then(() => {
    if (initialTag) {
      selectedTag = normalizeTag(initialTag);
    }
    input.value = initialQuery;
    render(initialQuery);
  });
</script>

<style>
  .links-page {
    max-width: var(--width-content);
    width: 100%;
    margin: 0 auto;
  }

  .links-header {
    margin-bottom: var(--space-xl);
  }

  .links-subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: start;
  }

  .links-tags h2 {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: var(--space-sm);
  }

  .tags-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  :global(.tag-btn) {
    border: 1px solid var(--color-border);
    background: var(--color-pill-bg);
    text-align: left;
    padding: 0.24rem 0.72rem;
    border-radius: 999px;
    cursor: pointer;
    color: var(--color-text-secondary);
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }

  :global(.tag-btn:hover) {
    color: var(--color-text);
    border-color: color-mix(in srgb, var(--color-border) 65%, #b9b3a5 35%);
    background: #ece4d3;
  }

  :global(.tag-btn.active) {
    color: var(--color-bg);
    border-color: var(--color-text);
    background: var(--color-text);
  }

  .links-input-wrap {
    margin-bottom: var(--space-lg);
  }

  #links-input {
    width: 100%;
    font-family: var(--font-heading);
    font-size: 1rem;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s ease;
  }

  #links-input:focus {
    border-color: var(--color-text-tertiary);
  }

  :global(.links-results) {
    list-style: none;
    padding: 0;
  }

  :global(.links-result-item) {
    border-bottom: 1px solid var(--color-border);
  }

  :global(.links-result-item:first-child) {
    border-top: 1px solid var(--color-border);
  }

  :global(.links-result-item a) {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: var(--color-text);
  }

  :global(.links-result-item a:hover .result-title) {
    color: var(--color-text-secondary);
  }

  :global(.result-title) {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  :global(.result-description) {
    display: block;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  :global(.result-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.15rem;
  }

  :global(.result-tag) {
    border: 1px solid var(--color-border);
    background: var(--color-pill-bg);
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    font-family: var(--font-heading);
    font-size: 0.72rem;
    color: var(--color-text-secondary);
  }

  :global(.result-date) {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
  }

  .links-empty {
    font-family: var(--font-heading);
    color: var(--color-text-tertiary);
  }

  @media (max-width: 900px) {
    .links-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
